                    <label>Species</label>
                    <input type="text" name="system.identity.species" value="{{system.identity.species}}" />
                </div>
                <div>
                    <label>Homeworld</label>
                    <input type="text" name="system.identity.homeworld" value="{{system.identity.homeworld}}" />
                </div>
                <div>
                    <label>Level</label>
                    <input type="number" name="system.identity.level" value="{{system.identity.level}}" />
                </div>
                <div>
                    <label>Hit Die</label>
                    <input type="number" name="system.identity.hitDie" value="{{system.identity.hitDie}}" />
                </div>
                <div>
                    <label>Max HP</label>
                    <input type="number" name="system.hp.max" value="{{system.hp.max}}" />
