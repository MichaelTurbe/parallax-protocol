                    <label>Current HP</label>
                    <input type="number" name="system.hp.value" value="{{system.hp.value}}" />
                </div>
            </div>
        </div> --}}
    </header>
    <section class="sheet-body" >
        <div class="tab-panel dossier-layout {{#unless (eq activeTab 'dossier')}}hidden{{/unless}}">
            <section class="card portrait-card">
                <div class="portrait-wrapper">
                    <img class="actor-portrait" src="{{actorImage}}" alt="{{actor.name}}" />
                </div>
                <div class="portrait-actions">
                    <button type="button" data-pp-action="choosePortrait">Choose Art</button>
                    <button type="button" data-pp-action="clearPortrait">Clear</button>
                </div>
            </section>
            <section class="stats-column">
                <section class="card">
                    <h4>Stats</h4>
                    <div class="stat-grid character-stat-grid">
                        <label><span class="stat-label">STR</span> <input type="number" name="system.stats.str.value" value="{{system.stats.str.value}}" /></label>
                        <label><span class="stat-label">DEX</span> <input type="number" name="system.stats.dex.value" value="{{system.stats.dex.value}}" /></label>
                        <label><span class="stat-label">CON</span> <input type="number" name="system.stats.con.value" value="{{system.stats.con.value}}" /></label>
                        <label><span class="stat-label">INT</span> <input type="number" name="system.stats.int.value" value="{{system.stats.int.value}}" /></label>
                        <label><span class="stat-label">WIS</span> <input type="number" name="system.stats.wis.value" value="{{system.stats.wis.value}}" /></label>
                        <label><span class="stat-label">CHA</span> <input type="number" name="system.stats.cha.value" value="{{system.stats.cha.value}}" /></label>
                    </div>
                </section>

                <section class="card hit-die-card top-gap">
                    <h4>Hit Die</h4>
                    <label>Hit Die
                        <select name="system.identity.hitDie">
                            {{selectOptions hitDieOptions selected=system.identity.hitDie}}
                        </select>
                    </label>
                    <button type="button" class="top-gap" data-pp-action="rollHitDie">Roll Hit Die</button>
                </section>
            </section>
                            <section class="card">
                                <h4>Saving Throws</h4>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Save</th>
                                            <th>Her.</th>
                                            <th>Item</th>
                                            <th>Target</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {{#each system.saves as |save key|}}
                                        <tr>
                                            <td>{{save.label}}</td>
                                            <td><input type="number" name="system.saves.{{key}}.hereditaryBonus" value="{{save.hereditaryBonus}}" />
                                            </td>
                                            <td><input type="number" name="system.saves.{{key}}.itemBonus" value="{{save.itemBonus}}" /></td>
                                            <td>{{save.target}}</td>
                                            <td class="row-actions">
                                                <button type="button" data-pp-action="rollSave" data-save-key="{{key}}">Roll</button>
                                            </td>
                                        </tr>
                                        {{/each}}
                                    </tbody>
                                </table>
                            </section>

        </div>
        <div class="tab-panel {{#unless (eq activeTab 'combat')}}hidden{{/unless}}">
                        <section class="card" style="width: 100%;">
                            <div style="display: flex; flex-direction:row; justify-content:space-between">
                                <h4>Weapons</h4>
                                <div class="inline-actions" style="display: flex; flex-direction:row;">
                                    <button type="button" data-pp-action="createItem" data-item-type="weapon" data-classification="melee">+ Melee
                                        Weapon</button>
                                    <button type="button" data-pp-action="createItem" data-item-type="weapon" data-classification="smallArms">+
                                        Ranged Weapon</button>
                                </div>
                            </div>
                            
                            <h4>Melee</h4>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Atk</th>
                                        <th>Dmg</th>
                                        <th>Type</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each meleeWeapons}}
                                    <tr>
                                        <td>{{name}}</td>
                                        <td>{{attackBonus}}</td>
                                        <td>{{system.damageSingle}}</td>
                                        <td>{{system.damageType}}</td>
                                        <td class="row-actions">
                                            <button type="button" data-pp-action="rollWeaponAttackCheck" data-item-id="{{id}}">Check</button>
                                            <button type="button" data-pp-action="rollWeaponAttackContest" data-item-id="{{id}}">Contest</button>
                                            <button type="button" data-pp-action="editItem" data-item-id="{{id}}">Edit</button>
                                            <button type="button" data-pp-action="deleteItem" data-item-id="{{id}}">X</button>
                                        </td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                            <h4>Ranged</h4>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Atk</th>
                                        <th>Single</th>
                                        <th>Auto</th>
                                        <th>Rng</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each rangedWeapons}}
                                    <tr>
                                        <td>{{name}}</td>
                                        <td>{{attackBonus}}</td>
                                        <td>{{system.damageSingle}}</td>
                                        <td>{{system.damageAutomatic}}</td>
                                        <td>{{system.rangeShort}} / {{system.rangeLong}} / {{system.rangeMax}}</td>
                                        <td class="row-actions">
                                            <button type="button" data-pp-action="rollWeaponAttackCheck" data-item-id="{{id}}">Check</button>
                                            <button type="button" data-pp-action="rollWeaponAttackContest" data-item-id="{{id}}">Contest</button>
                                            <button type="button" data-pp-action="editItem" data-item-id="{{id}}">Edit</button>
                                            <button type="button" data-pp-action="deleteItem" data-item-id="{{id}}">X</button>
                                        </td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </section>
            <div class="three-col">

                <section class="card">
                    <h4>Movement & Load</h4>
                    <div class="summary-grid">
                        <label>Base Speed <input type="number" name="system.movement.base" value="{{system.movement.base}}" /></label>
                        <label>Armor Penalty <input type="number" name="system.movement.armorPenalty" value="{{system.movement.armorPenalty}}" /></label>
                        <label>With Pack Penalty <input type="number" name="system.movement.burdenedPenaltyWithPack" value="{{system.movement.burdenedPenaltyWithPack}}" /></label>
                        <label>Without Pack Penalty <input type="number" name="system.movement.burdenedPenaltyWithoutPack" value="{{system.movement.burdenedPenaltyWithoutPack}}" /></label>
                        <div>Load Rating <strong>{{system.load.rating}}</strong></div>
                        <div>Total Bulk With Pack <strong>{{system.load.totalBulkWithPack}}</strong></div>
                        <div>Total Bulk Without Pack <strong>{{system.load.totalBulkWithoutPack}}</strong></div>
                        <div>Speed With Pack <strong>{{system.movement.totalWithPack}}</strong></div>
                        <div>Speed Without Pack <strong>{{system.movement.totalWithoutPack}}</strong></div>
                    </div>
                </section>

                <section class="card">
                    <h4>Combat Summary</h4>
                    <div class="summary-grid compact">
                        <div>Awareness Bonus <strong>{{system.combat.awareness.totalBonus}}</strong></div>
                        <div>Deflection Bonus <strong>{{system.combat.deflection.totalBonus}}</strong></div>
                        <div>Evasion Bonus <strong>{{system.combat.evasion.totalBonus}}</strong></div>
                        <div>Initiative Bonus <strong>{{system.combat.initiativeBonus}}</strong></div>
                        {{!-- <button type="button" data-pp-action="rollInitiative">Roll Initiative</button> --}}
                        <button type="button" class="pp-icon-button" data-pp-action="rollInitiative">
                        
                            <span class="pp-icon-button__text">Roll Initiative</span>
                        
                            <img class="pp-icon-button__icon" src="systems/parallax-protocol/assets/icons/coinflip.svg" alt=""
                                aria-hidden="true" />
                        
                        </button>
                    </div>
                </section>
            </div>

            <div class="two-col wide-gap">
                <section class="card">
                    <h4>Damage Reduction</h4>
                    <table>
                        <thead>
                            <tr><th></th><th>Kinetic</th><th>Energy</th></tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Body</td>
                                <td><input type="number" name="system.armorSummary.body.kinetic" value="{{system.armorSummary.body.kinetic}}" /></td>
                                <td><input type="number" name="system.armorSummary.body.energy" value="{{system.armorSummary.body.energy}}" /></td>
                            </tr>
                            <tr><td>Armor</td><td>{{system.armorSummary.armor.kinetic}}</td><td>{{system.armorSummary.armor.energy}}</td></tr>
                            <tr><td>Field</td><td>{{system.armorSummary.field.kinetic}}</td><td>{{system.armorSummary.field.energy}}</td></tr>
                            <tr class="total-row"><td>Total</td><td>{{system.armorSummary.total.kinetic}}</td><td>{{system.armorSummary.total.energy}}</td></tr>
                        </tbody>
                    </table>
                </section>


            </div>
        </div>

        <div class="tab-panel {{#unless (eq activeTab 'skills')}}hidden{{/unless}}">
            <div style="display: flex;"">
                <section class="card" style="width: 100%; display: flex; flex-direction: row;">
                    <h4>Skill Focus Priorities</h4>
                    <div style="display: flex; flex-direction:row; gap: 5px;">
                        <label>First
                            <select name="system.priorities.first">
                                {{selectOptions priorities selected=system.priorities.first}}
                            </select>
                        </label>
                        <label>Second
                            <select name="system.priorities.second">
                                {{selectOptions priorities selected=system.priorities.second}}
                            </select>
                        </label>
                        <label>Third
                            <select name="system.priorities.third">
                                {{selectOptions priorities selected=system.priorities.third}}
                            </select>
                        </label>
                        <label>Fourth
                            <select name="system.priorities.fourth">
                                {{selectOptions priorities selected=system.priorities.fourth}}
                            </select>
                        </label>
                    </div>
                    {{!-- <div class="summary-grid compact top-gap">
                        <div>Martial <strong>{{system.trainedSkillBonuses.martial}}</strong></div>
                        <div>Intellectual <strong>{{system.trainedSkillBonuses.intellectual}}</strong></div>
                        <div>Physical <strong>{{system.trainedSkillBonuses.physical}}</strong></div>
                        <div>Subtle <strong>{{system.trainedSkillBonuses.subtle}}</strong></div>
                    </div> --}}
                </section>


            </div>

            {{#each skillsByCategory as |skills categoryKey|}}
            <section class="card top-gap">
                <h4>{{lookup ../skillCategories categoryKey}} Skills</h4>
                <table>
                    <thead>
                        <tr><th>Skill</th><th>Stat</th><th>Trained</th><th>Trained Skill Bonus</th><th>Item</th><th>Total</th><th>Target</th><th></th></tr>
                    </thead>
                    <tbody>
                        {{#each skills}}
                        <tr data-skill-row="{{key}}">
                            <td>{{label}}</td>
                            <td>{{statLabel}}</td>
                            <td><input type="checkbox" name="system.skills.{{key}}.trained" {{checked trained}} /></td>
                            <td><input type="number" name="system.skills.{{key}}.trainedSkillBonus" value="{{trainedSkillBonus}}" /></td>
                            <td><input type="number" name="system.skills.{{key}}.itemBonus" value="{{itemBonus}}" /></td>
                            <td data-skill-total>{{totalBonus}}</td>
                            <td data-skill-target>{{target}}</td>
                            <td class="row-actions">
                                <button type="button" data-pp-action="rollSkillCheck" data-skill-key="{{key}}">Check</button>
                                <button type="button" data-pp-action="rollSkillContest" data-skill-key="{{key}}">Contest</button>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </section>
            {{/each}}
        </div>

        <div class="tab-panel {{#unless (eq activeTab 'items')}}hidden{{/unless}}">
            <div class="three-col">
                <section class="card">
                    <h4>Armor</h4>
                    <div class="inline-actions"><button type="button" data-pp-action="createItem" data-item-type="armor">+ Armor</button></div>
                    <ul class="item-list">
                        {{#each armorItems}}
                        <li>
                            <span>{{name}}</span>
                            <span class="row-actions">
                                <button type="button" data-pp-action="editItem" data-item-id="{{id}}">Edit</button>
                                <button type="button" data-pp-action="deleteItem" data-item-id="{{id}}">X</button>
                            </span>
                        </li>
                        {{/each}}
                    </ul>
                </section>

                <section class="card">
                    <h4>Fields</h4>
                    <div class="inline-actions"><button type="button" data-pp-action="createItem" data-item-type="field">+ Field</button></div>
                    <ul class="item-list">
                        {{#each fieldItems}}
                        <li>
                            <span>{{name}}</span>
                            <span class="row-actions">
                                <button type="button" data-pp-action="editItem" data-item-id="{{id}}">Edit</button>
                                <button type="button" data-pp-action="deleteItem" data-item-id="{{id}}">X</button>
                            </span>
                        </li>
                        {{/each}}
                    </ul>
                </section>

                <section class="card">
                    <h4>Species Traits</h4>
                    <div class="inline-actions"><button type="button" data-pp-action="createItem" data-item-type="speciesTrait">+ Trait</button></div>
                    <ul class="item-list">
                        {{#each speciesTraits}}
                        <li>
                            <span>{{name}}</span>
                            <span class="row-actions">
                                <button type="button" data-pp-action="editItem" data-item-id="{{id}}">Edit</button>
                                <button type="button" data-pp-action="deleteItem" data-item-id="{{id}}">X</button>
                            </span>
                        </li>
                        {{/each}}
                    </ul>
                </section>
            </div>

            <section class="card top-gap">
                <h4>Gear</h4>
                <div class="inline-actions"><button type="button" data-pp-action="createItem" data-item-type="gear">+ Gear</button></div>
                <table>
                    <thead><tr><th>Name</th><th>Type</th><th>Bulk</th><th>Pack?</th><th></th></tr></thead>
                    <tbody>
                        {{#each gear}}
                        <tr>
                            <td>{{name}}</td>
                            <td>{{system.category}}</td>
                            <td>{{system.bulk}}</td>
                            <td>{{#if system.inPack}}Yes{{else}}No{{/if}}</td>
                            <td class="row-actions">
                                <button type="button" data-pp-action="editItem" data-item-id="{{id}}">Edit</button>
                                <button type="button" data-pp-action="deleteItem" data-item-id="{{id}}">X</button>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </section>

            <section class="card top-gap">
                <h4>Notes</h4>
                <textarea name="system.notes">{{system.notes}}</textarea>
            </section>
        </div>
    </section>
</div>
